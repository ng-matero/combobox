{
  "name": "combobox-srcs",
  "version": "0.0.0-NOT-USED",
  "engines": {
    "yarn": ">=1.22.0 <2",
    "npm": "Please use Yarn instead of NPM to install dependencies"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve dev-app",
    "build": "ng build dev-app --base-href=/combobox/",
    "watch": "ng build dev-app --watch --configuration development",
    "test": "ng test dev-app",
    "lint": "ng lint --fix && npm run lint:scss",
    "lint:ts": "eslint \"projects/**/*.ts\" --fix",
    "lint:scss": "stylelint \"projects/**/*.scss\" --fix",
    "test:lib": "ng test ng-select",
    "build:lib": "ng build ng-select && cp README.md dist/ng-select",
    "publish": "npm run build:lib && cd dist/ng-select && npm publish",
    "deploy": "npm run build && ng deploy",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "ngx-highlightjs": "^14.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/jasmine": "~5.1.0",
    "@types/lodash-es": "^4.17.10",
    "angular-cli-ghpages": "^3.0.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.0",
    "husky": "^9.1.6",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.3",
    "prettier": "^3.8.0",
    "stylelint": "^16.5.0",
    "stylelint-config-recommended-scss": "^14.0.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.0"
  }
}
